{# dashboard_premium.html.j2 — Premium dashboard template.
   Ported from rt-noopenclaw production template system.

   Expects report JSON with: titulo, subtitulo, data_analise,
   hero (headline, subheadline, severity, action_required),
   kpis (label, value, detail, severity),
   sections (id, titulo, content_markdown, collapsible),
   finding_cards (severity, title, detail, clause_ref, recommendation),
   Optional: scope_summary (covered, partial, excluded),
   Optional: assurance_tiers (tier_cards with emoji, label, count)
#}
<!DOCTYPE html>
<html lang="{{ language | default('pt-BR') }}">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>{{ titulo | default('Relatório') }}</title>
<link rel="preconnect" href="https://fonts.googleapis.com">
<link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800&display=swap" rel="stylesheet">
<style>
/* ── Design tokens (from rt-noopenclaw production) ── */
{% include "base/premium/tokens.css" %}

/* ── Base styles ── */
{% include "base/premium/base.css" %}

/* ── Dashboard-specific ── */
.container { max-width: 960px; margin: 0 auto; padding: 24px; }

.hero-section {
  background: linear-gradient(180deg, #f7fafc 0%, #eef3f8 100%);
  border: 1px solid #d9e2ec;
  border-radius: 22px;
  padding: 40px;
  box-shadow: 0 20px 48px rgba(15,23,42,.08);
  margin-bottom: 34px;
}
.hero-title { font-size: 36px; line-height: 1.1; color: #102a43; margin: 0 0 10px; font-weight: 800; }
.hero-subtitle { max-width: 760px; color: #334e68; font-size: 16px; margin-bottom: 16px; }
.hero-action {
  display: inline-block;
  padding: 12px 20px;
  border-radius: 12px;
  font-weight: 700;
  font-size: 14px;
}
.hero-action.critical { background: #fff5f5; border: 1px solid #fca5a5; color: #991b1b; }
.hero-action.warning { background: #fffaf0; border: 1px solid #fde68a; color: #92400e; }
.hero-action.ok { background: #f0fdf4; border: 1px solid #bbf7d0; color: #166534; }

.meta-bar { display: flex; gap: 12px; flex-wrap: wrap; margin: 20px 0 0; }

.kpi-grid { display: grid; grid-template-columns: repeat(auto-fit, minmax(180px, 1fr)); gap: 14px; margin: 24px 0; }
.kpi-card { background: #fff; border: 1px solid #d9e2ec; border-radius: 16px; padding: 20px; text-align: center; }
.kpi-value { font-size: 32px; font-weight: 800; color: #102a43; }
.kpi-label { font-size: 13px; color: #486581; margin-top: 4px; }
.kpi-detail { font-size: 11px; color: #829ab1; margin-top: 2px; }
.kpi-card.sev-critical { background: #fff5f5; border-color: #f3c0c0; }
.kpi-card.sev-critical .kpi-value { color: #9b1c1c; }
.kpi-card.sev-warning { background: #fffaf0; border-color: #ead3a1; }
.kpi-card.sev-warning .kpi-value { color: #9f580a; }
.kpi-card.sev-high { background: #fff5f5; border-color: #f3c0c0; }
.kpi-card.sev-high .kpi-value { color: #9b1c1c; }

.content-section {
  background: #fff;
  border: 1px solid #d9e2ec;
  border-radius: 16px;
  padding: 28px;
  margin-bottom: 18px;
  box-shadow: 0 4px 12px rgba(15,23,42,.04);
}
.content-section h2 {
  font-size: 18px;
  color: #102a43;
  font-weight: 700;
  margin: 0 0 16px;
  padding-bottom: 10px;
  border-bottom: 2px solid #eef3f8;
}
.content-section table { width: 100%; border-collapse: collapse; margin: 12px 0; font-size: 13px; }
.content-section th { background: #f7fafc; text-align: left; padding: 10px 12px; border-bottom: 2px solid #d9e2ec; font-weight: 700; color: #334e68; }
.content-section td { padding: 10px 12px; border-bottom: 1px solid #eef3f8; vertical-align: top; }
.content-section tr:hover { background: #f7fafc; }

/* Collapsible sections */
details.content-section { padding: 0; }
details.content-section > summary {
  padding: 20px 28px;
  cursor: pointer;
  list-style: none;
  display: flex;
  align-items: center;
  justify-content: space-between;
}
details.content-section > summary::-webkit-details-marker { display: none; }
details.content-section > summary h2 { margin: 0; padding: 0; border: 0; }
details.content-section > summary::after { content: '▸'; color: #829ab1; font-size: 14px; transition: transform 0.2s; }
details.content-section[open] > summary::after { transform: rotate(90deg); }
details.content-section > .section-body { padding: 0 28px 28px; }

/* Finding cards */
.findings-section { margin: 24px 0; }
.finding-card {
  border-left: 5px solid;
  border-radius: 12px;
  padding: 18px;
  margin: 14px 0;
  background: #fff;
  border: 1px solid #d9e2ec;
  box-shadow: 0 2px 8px rgba(15,23,42,.04);
}
.finding-card.critical { border-left-color: #991b1b; background: #fff7f7; }
.finding-card.high { border-left-color: #991b1b; background: #fff7f7; }
.finding-card.medium { border-left-color: #92400e; background: #fffcf0; }
.finding-card.low { border-left-color: #1d4ed8; background: #f8fbff; }
.finding-card .card-header { display: flex; align-items: center; gap: 10px; margin-bottom: 10px; }
.finding-card .card-title { font-weight: 700; color: #102a43; flex: 1; }
.finding-card .card-detail { color: #334e68; font-size: 14px; line-height: 1.6; }
.finding-card .card-ref { font-size: 12px; color: #486581; margin-top: 8px; }
.finding-card .card-recommendation {
  margin-top: 10px;
  padding-top: 10px;
  border-top: 1px solid #eef3f8;
  font-size: 13px;
  color: #334e68;
}

.footer { margin-top: 48px; padding-top: 16px; border-top: 1px solid #e2e8f0; font-size: 12px; color: #829ab1; text-align: center; }

@media print {
  .hero-section { box-shadow: none; border-radius: 0; border: none; break-after: page; }
  .content-section { box-shadow: none; break-inside: avoid; }
  details.content-section { display: block; }
  details.content-section[open] > summary { display: none; }
  .finding-card { break-inside: avoid; }
}
@media (max-width: 900px) {
  .kpi-grid { grid-template-columns: 1fr 1fr; }
  .hero-title { font-size: 28px; }
  .hero-section { padding: 24px; }
}
</style>
</head>
<body>
<div class="container">

{# ── Hero ── #}
{% set hero = hero | default({}) %}
<section class="hero-section">
  <div class="hero-title">{{ hero.headline | default(titulo) }}</div>
  <p class="hero-subtitle">{{ hero.subheadline | default(subtitulo) }}</p>
  {% if hero.action_required %}
  <div class="hero-action {{ hero.severity | default('ok') }}">{{ hero.action_required }}</div>
  {% endif %}
  <div class="meta-bar">
    {% if data_analise %}<div class="meta-chip"><strong>Data:</strong> {{ data_analise }}</div>{% endif %}
    {% if subtitulo %}<div class="meta-chip">{{ subtitulo }}</div>{% endif %}
  </div>
</section>

{# ── KPIs ── #}
{% if kpis %}
<div class="kpi-grid">
  {% for kpi in kpis %}
  <div class="kpi-card {{ 'sev-' + kpi.severity if kpi.severity else '' }}">
    <div class="kpi-value">{{ kpi.value }}</div>
    <div class="kpi-label">{{ kpi.label }}</div>
    {% if kpi.detail %}<div class="kpi-detail">{{ kpi.detail }}</div>{% endif %}
  </div>
  {% endfor %}
</div>
{% endif %}

{# ── Sections ── #}
{% for section in sections | default([]) %}
  {% if section.collapsible %}
  <details class="content-section" id="{{ section.id | default('') }}">
    <summary><h2>{{ section.titulo }}</h2></summary>
    <div class="section-body">{{ section.content_markdown | md }}</div>
  </details>
  {% else %}
  <section class="content-section" id="{{ section.id | default('') }}">
    <h2>{{ section.titulo }}</h2>
    <div>{{ section.content_markdown | md }}</div>
  </section>
  {% endif %}
{% endfor %}

{# ── Finding Cards ── #}
{% if finding_cards %}
<section class="content-section findings-section">
  <h2>Achados Principais</h2>
  {% for card in finding_cards %}
  <div class="finding-card {{ card.severity | default('medium') }}">
    <div class="card-header">
      <span class="severity-chip sev-chip-{{ card.severity | default('medium') }}">{{ (card.severity | default('medium')) | upper }}</span>
      <span class="card-title">{{ card.title }}</span>
    </div>
    <div class="card-detail">{{ card.detail }}</div>
    {% if card.clause_ref %}<div class="card-ref">Referência: {{ card.clause_ref }}</div>{% endif %}
    {% if card.recommendation %}
    <div class="card-recommendation"><strong>Recomendação:</strong> {{ card.recommendation }}</div>
    {% endif %}
  </div>
  {% endfor %}
</section>
{% endif %}

<div class="footer">
  Gerado automaticamente por pipeline-engine · {{ data_analise | default('') }}
</div>

</div>
</body>
</html>
