<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>{% block title %}{{ title | default('Report', true) }}{% endblock %}</title>
<!-- Inter font from Google Fonts CDN (fallback to system fonts if offline) -->
<link rel="preconnect" href="https://fonts.googleapis.com">
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
<link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&display=swap" rel="stylesheet">
<style>
/* ── Theme tokens (inlined for self-containment) ── */
{% include "base/theme.css" %}

/* ── Page setup for PDF ── */
@page {
  size: A4;
  margin: 2cm 1.8cm;
  @bottom-center { content: counter(page); font-size: 9pt; color: var(--color-muted); }
}

/* ── Base reset & typography ── */
*, *::before, *::after { box-sizing: border-box; }
body {
  margin: 0;
  padding: 0;
  font-family: var(--font-family);
  font-size: var(--font-size-base);
  line-height: var(--line-height);
  color: var(--color-text);
  background: var(--color-bg);
  -webkit-font-smoothing: antialiased;
  -moz-osx-font-smoothing: grayscale;
}
h1, h2, h3, h4, h5, h6, p { margin-top: 0; }
h1 { font-size: var(--font-size-2xl); color: var(--color-primary); line-height: var(--line-height-tight); margin-bottom: var(--sp-3); }
h2 { font-size: var(--font-size-xl);  color: var(--color-primary); margin-bottom: var(--sp-4); }
h3 { font-size: var(--font-size-lg);  color: var(--color-primary-light); margin-bottom: var(--sp-3); }
h4 { font-size: var(--font-size-md);  color: var(--color-text); margin-bottom: var(--sp-2); }
a { color: var(--color-accent); text-decoration: none; }
a:hover { text-decoration: underline; }

/* ── Layout shell ── */
.layout-wrapper {
  display: grid;
  grid-template-columns: var(--sidebar-width) 1fr;
  grid-template-rows: auto 1fr auto;
  grid-template-areas:
    "header  header"
    "sidebar content"
    "footer  footer";
  min-height: 100vh;
  max-width: calc(var(--content-max) + var(--sidebar-width) + var(--sp-12));
  margin: 0 auto;
}

/* ── Header ── */
.layout-header {
  grid-area: header;
  display: flex;
  justify-content: space-between;
  align-items: center;
  flex-wrap: wrap;
  gap: var(--sp-4);
  padding: var(--sp-6) var(--sp-8);
  background: linear-gradient(180deg, var(--color-surface) 0%, var(--color-surface-alt) 100%);
  border-bottom: 1px solid var(--color-border);
  box-shadow: var(--shadow-sm);
}
.header-title-group { flex: 1 1 auto; min-width: 0; }
.header-title-group h1 { margin-bottom: var(--sp-1); }
.header-meta {
  display: flex;
  gap: var(--sp-3);
  flex-wrap: wrap;
  align-items: center;
}
.header-chip {
  display: inline-flex;
  align-items: center;
  gap: var(--sp-1);
  padding: var(--sp-1) var(--sp-3);
  border-radius: var(--radius-pill);
  background: var(--color-accent-soft);
  color: var(--color-accent);
  font-size: var(--font-size-xs);
  font-weight: 700;
  letter-spacing: 0.03em;
  white-space: nowrap;
}

/* ── Sidebar navigation ── */
.layout-sidebar {
  grid-area: sidebar;
  padding: var(--sp-6) var(--sp-5);
  background: var(--color-surface);
  border-right: 1px solid var(--color-border);
  position: sticky;
  top: 0;
  height: 100vh;
  overflow-y: auto;
}
.sidebar-nav { list-style: none; padding: 0; margin: 0; }
.sidebar-nav li { margin-bottom: var(--sp-1); }
.sidebar-nav a {
  display: block;
  padding: var(--sp-2) var(--sp-3);
  border-radius: var(--radius-sm);
  color: var(--color-text-secondary);
  font-size: var(--font-size-sm);
  font-weight: 500;
  transition: background 0.15s ease, color 0.15s ease;
  text-decoration: none;
}
.sidebar-nav a:hover {
  background: var(--color-primary-bg);
  color: var(--color-primary);
  text-decoration: none;
}
.sidebar-label {
  display: block;
  padding: var(--sp-3) var(--sp-3) var(--sp-2);
  font-size: var(--font-size-xs);
  font-weight: 700;
  text-transform: uppercase;
  letter-spacing: 0.08em;
  color: var(--color-muted);
}

/* ── Main content ── */
.layout-content {
  grid-area: content;
  padding: var(--sp-8);
  min-width: 0;
}

/* ── Footer ── */
.layout-footer {
  grid-area: footer;
  padding: var(--sp-5) var(--sp-8);
  background: var(--color-surface);
  border-top: 1px solid var(--color-border);
  font-size: var(--font-size-xs);
  color: var(--color-muted);
  display: flex;
  justify-content: space-between;
  flex-wrap: wrap;
  gap: var(--sp-3);
}
.footer-version {
  padding-top: var(--sp-2);
  border-top: 1px solid var(--color-border-light);
}

/* ── Section spacing ── */
.content-section {
  margin-bottom: var(--sp-10);
}
.content-section:last-child {
  margin-bottom: 0;
}

/* ── Mobile responsive ── */
@media (max-width: 900px) {
  .layout-wrapper {
    grid-template-columns: 1fr;
    grid-template-areas:
      "header"
      "content"
      "footer";
  }
  .layout-sidebar {
    display: none;
  }
  .layout-header {
    padding: var(--sp-4) var(--sp-5);
  }
  .layout-content {
    padding: var(--sp-5);
  }
  h1 { font-size: var(--font-size-xl); }
}

/* ── Print styles ── */
@media print {
  body { background: white; }
  .layout-wrapper {
    display: block;
    max-width: 100%;
  }
  .layout-sidebar { display: none; }
  .layout-header {
    box-shadow: none;
    border-bottom: 2px solid var(--color-primary);
    background: white;
  }
  .layout-content { padding: var(--sp-5) 0; }
  .layout-footer {
    border-top: 1px solid var(--color-border);
    background: white;
  }
  .content-section { break-inside: avoid; }
  table { break-inside: avoid; }
  .pe-card { break-inside: avoid; }
  .pe-finding { break-inside: avoid; }
  .pe-kpi-row { break-inside: avoid; }
  .pe-alert { break-inside: avoid; }
  h2, h3 { break-after: avoid; }
  a { color: var(--color-text); }
  a::after { content: none; }
}
</style>
{% block head_extra %}{% endblock %}
</head>
<body>
<div class="layout-wrapper">

  {# ── Header ── #}
  <header class="layout-header">
    <div class="header-title-group">
      <h1>{% block header_title %}{{ title | default('Report', true) }}{% endblock %}</h1>
      <div class="header-meta">
        {% if pipeline is defined and pipeline %}
          <span class="header-chip">{{ pipeline }}</span>
        {% endif %}
        {% if date is defined and date %}
          <span class="header-chip">{{ date }}</span>
        {% endif %}
        {% block header_meta_extra %}{% endblock %}
      </div>
    </div>
    {% block header_actions %}{% endblock %}
  </header>

  {# ── Sidebar ── #}
  <nav class="layout-sidebar" aria-label="Section navigation">
    {% block sidebar %}
    <span class="sidebar-label">Sections</span>
    <ul class="sidebar-nav">
      {% for section in sections | default([]) %}
        <li><a href="#{{ section.id }}">{{ section.label }}</a></li>
      {% endfor %}
    </ul>
    {% endblock %}
  </nav>

  {# ── Content ── #}
  <main class="layout-content">
    {% block content %}{% endblock %}
  </main>

  {# ── Footer ── #}
  <footer class="layout-footer">
    {% block footer %}
    <div>
      Generated {{ date | default('—', true) }}
      {% if pipeline is defined and pipeline %} | Pipeline: {{ pipeline }}{% endif %}
    </div>
    <div>Pipeline Engine Report System</div>
    {% endblock %}
  </footer>

</div>
{% block scripts %}{% endblock %}
</body>
</html>
