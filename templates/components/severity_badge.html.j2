{# severity_badge.html.j2 -- Severity level badge (alta/media/baixa).
   Usage: {% from "components/severity_badge.html.j2" import severity %}
          {{ severity("alta") }}
#}
{% macro severity(level) %}
{%- set lvl = (level | default('baixa') | lower | trim) -%}
<style>
.pe-severity {
  display: inline-flex;
  align-items: center;
  padding: 3px 10px;
  border-radius: 999px;
  font-size: 11px;
  font-weight: 800;
  letter-spacing: 0.03em;
  text-transform: uppercase;
  white-space: nowrap;
  border: 1px solid transparent;
}
.pe-severity--alta   { background: var(--color-sev-alta-bg, #fee2e2); color: var(--color-sev-alta, #991b1b); border-color: var(--color-sev-alta-border, #fca5a5); }
.pe-severity--media  { background: var(--color-sev-media-bg, #fef3c7); color: var(--color-sev-media, #92400e); border-color: var(--color-sev-media-border, #fde68a); }
.pe-severity--baixa  { background: var(--color-sev-baixa-bg, #dbeafe); color: var(--color-sev-baixa, #1d4ed8); border-color: var(--color-sev-baixa-border, #93c5fd); }
</style>
<span class="pe-severity pe-severity--{{ lvl }}">{{ lvl | replace('_', ' ') }}</span>
{%- endmacro %}
