{# finding_card.html.j2 -- Finding card with severity, description, sources, confidence.
   Usage: {% from "components/finding_card.html.j2" import finding %}
          {{ finding("Revenue drop", "alta", "Revenue dropped 30%",
                     sources=["DRE 2025"], confidence="blindado") }}
#}
{% macro finding(title, severity, description, sources=[], confidence=None) %}
{%- set sev = (severity | default('baixa') | lower | trim) -%}
{%- set border_color = 'var(--color-sev-alta-border, #fca5a5)' if sev == 'alta'
    else ('var(--color-sev-media-border, #fde68a)' if sev == 'media'
    else 'var(--color-sev-baixa-border, #93c5fd)') -%}
<style>
.pe-finding {
  border: 1px solid var(--color-border-light, #e2e8f0);
  border-left: 4px solid var(--color-accent, #1d4ed8);
  border-radius: var(--radius-md, 10px);
  padding: 16px 18px;
  margin-bottom: 16px;
  background: var(--color-surface, #fff);
  box-shadow: var(--shadow-sm, 0 1px 2px rgba(15,23,42,.04));
  break-inside: avoid;
}
.pe-finding-header {
  display: flex;
  justify-content: space-between;
  align-items: flex-start;
  gap: 12px;
  flex-wrap: wrap;
  margin-bottom: 10px;
}
.pe-finding-title {
  margin: 0;
  font-size: 16px;
  font-weight: 800;
  color: var(--color-text, #1f2937);
  flex: 1 1 auto;
}
.pe-finding-badges {
  display: flex;
  gap: 8px;
  align-items: center;
  flex-wrap: wrap;
  flex-shrink: 0;
}
.pe-finding-desc {
  font-size: 14px;
  color: var(--color-text-secondary, #334e68);
  line-height: 1.65;
  margin-bottom: 10px;
}
.pe-finding-sources {
  display: flex;
  gap: 6px;
  flex-wrap: wrap;
  margin-top: 10px;
}
.pe-finding-source {
  display: inline-flex;
  align-items: center;
  padding: 2px 8px;
  border-radius: 999px;
  background: #f1f5f9;
  color: #475569;
  font-size: 11px;
  font-weight: 600;
  border: 1px solid #e2e8f0;
}
/* Severity badge (inline) */
.pe-finding .pe-sev-badge {
  display: inline-flex;
  align-items: center;
  padding: 3px 10px;
  border-radius: 999px;
  font-size: 11px;
  font-weight: 800;
  letter-spacing: 0.03em;
  text-transform: uppercase;
  white-space: nowrap;
  border: 1px solid transparent;
}
.pe-sev-badge--alta   { background: var(--color-sev-alta-bg, #fee2e2); color: var(--color-sev-alta, #991b1b); border-color: var(--color-sev-alta-border, #fca5a5); }
.pe-sev-badge--media  { background: var(--color-sev-media-bg, #fef3c7); color: var(--color-sev-media, #92400e); border-color: var(--color-sev-media-border, #fde68a); }
.pe-sev-badge--baixa  { background: var(--color-sev-baixa-bg, #dbeafe); color: var(--color-sev-baixa, #1d4ed8); border-color: var(--color-sev-baixa-border, #93c5fd); }
/* Confidence badge (inline) */
.pe-finding .pe-conf-badge {
  display: inline-flex;
  align-items: center;
  gap: 4px;
  padding: 3px 10px;
  border-radius: 999px;
  font-size: 11px;
  font-weight: 800;
  letter-spacing: 0.02em;
  text-transform: uppercase;
  border: 1px solid transparent;
}
.pe-conf-badge--blindado { background: var(--color-conf-blindado-bg, #d1fae5); color: var(--color-conf-blindado, #065f46); border-color: var(--color-conf-blindado-border, #6ee7b7); }
.pe-conf-badge--alta     { background: var(--color-conf-alta-bg, #fef3c7); color: var(--color-conf-alta, #92400e); border-color: var(--color-conf-alta-border, #fcd34d); }
.pe-conf-badge--sugestao { background: var(--color-conf-sugestao-bg, #dbeafe); color: var(--color-conf-sugestao, #1d4ed8); border-color: var(--color-conf-sugestao-border, #93c5fd); }
</style>
<div class="pe-finding" style="border-left-color: {{ border_color }};">
  <div class="pe-finding-header">
    <h4 class="pe-finding-title">{{ title }}</h4>
    <div class="pe-finding-badges">
      <span class="pe-sev-badge pe-sev-badge--{{ sev }}">{{ sev }}</span>
      {% if confidence %}
        {%- set conf = (confidence | lower | trim) -%}
        {%- set conf_key = 'blindado' if conf == 'blindado' else ('alta' if conf in ['alta_confianca', 'alta'] else 'sugestao') -%}
        {%- set conf_labels = {'blindado': 'Armored', 'alta': 'High', 'sugestao': 'Suggestion'} -%}
        <span class="pe-conf-badge pe-conf-badge--{{ conf_key }}">{{ conf_labels.get(conf_key, conf) }}</span>
      {% endif %}
    </div>
  </div>
  <div class="pe-finding-desc">{{ description }}</div>
  {% if sources %}
  <div class="pe-finding-sources">
    {% for src in sources %}
      <span class="pe-finding-source">{{ src }}</span>
    {% endfor %}
  </div>
  {% endif %}
</div>
{% endmacro %}
