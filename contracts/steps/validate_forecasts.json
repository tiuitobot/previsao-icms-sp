{
  "id": "validate_forecasts",
  "name": "Validate Forecasts",
  "description": "Deterministic validation: checks forecast consistency (sum of parts = annual total), model convergence, confidence interval sanity, and comparison against historical patterns.",
  "type": "deterministic",
  "extends": "_base_verifier",
  "script": "steps/validate_forecasts.py",
  "function": "main",
  "inputs": {
    "required": ["sarimax_results", "base_consolidada"],
