  "cost_estimate": {"fixed_usd": 0},
  "tags": ["validation", "consistency", "sanity-check"],
  "library": {
    "category": "concrete",
    "origin": "previsao-icms-sp",
    "domain": "financeiro",
    "subdomain": "macro"
  }
}
